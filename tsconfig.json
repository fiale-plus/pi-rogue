{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "paths": {
      "@fiale-plus/pi-core": ["./packages/core/src"],
      "@fiale-plus/pi-advisor": ["./packages/advisor/src"],
      "@fiale-plus/pi-rogue-orchestration": ["./packages/orchestration/src"],
      "@fiale-plus/pi-rogue-context-broker": ["./packages/context-broker/src"],
      "@fiale-plus/pi-rogue-context-broker/extension": ["./packages/context-broker/src/extension.ts"],
      "@fiale-plus/pi-rogue-context-broker/file": ["./packages/context-broker/src/file.ts"],
      "@fiale-plus/pi-rogue-context-broker/sqlite": ["./packages/context-broker/src/sqlite.ts"],
      "@fiale-plus/pi-rogue-guardrails": ["./packages/guardrails/src"],
      "@fiale-plus/pi-rogue-brain": ["./packages/brain/src"],
      "@fiale-plus/pi-rogue-repo-arch": ["./packages/repo-arch/src"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/orchestration/**/*.ts",
    "packages/*/pi/**/*.ts"
  ]
}
