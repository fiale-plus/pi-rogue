{
  "name": "pi-rogue",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-Rogue advisor extension repo and internal workspaces.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "npm run check -ws --if-present",
    "test": "npm run test -ws --if-present",
    "routing:mine": "npx tsx scripts/mine-routing-examples.ts",
    "routing:queue": "npx tsx scripts/build-routing-label-queue.ts",
    "routing:autolabel": "npx tsx scripts/auto-label-routing-queue.ts",
    "routing:advisor-log": "npx tsx scripts/mine-advisor-router-log.ts",
    "sessions:model-outcomes": "npx tsx scripts/mine-session-model-outcomes.ts",
    "binary:build": "npx tsx scripts/build-binary-gate-dataset.ts",
    "binary:train": "npx tsx scripts/train-binary-gate.ts",
    "binary:eval-sources": "npx tsx scripts/eval-binary-gate-sources.ts",
    "binary:review-conflicts": "npx tsx scripts/review-binary-gate-conflicts.ts",
    "binary:eval-candidates": "npx tsx scripts/eval-binary-gate-candidate-matrix.ts",
    "binary:eval-q1-q10": "npx tsx scripts/eval-binary-gate-q1-q10-augmentation.ts",
    "binary:q1-q10-queue": "npx tsx scripts/build-q1-q10-conflict-like-queue.ts",
    "binary:q1-q10-hard-negatives": "npx tsx scripts/build-q1-q10-hard-negative-packet.ts",
    "binary:q1-q10-over-escalation": "npx tsx scripts/build-q1-q10-over-escalation-augmentation.ts",
    "binary:benchmark": "npx tsx scripts/benchmark-binary-gate.ts",
    "routing:score": "npx tsx scripts/score-routing-active-learning.ts",
    "routing:eval": "npx tsx scripts/eval-routing-baselines.ts"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
