{
  "name": "pi-rogue",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-Rogue advisor extension repo and internal workspaces.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/lab/*"
  ],
  "scripts": {
    "check": "npm run check -ws --if-present && npm run check:scripts && npm run check:coverage",
    "check:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "check:coverage": "tsx scripts/validate-validation-coverage.ts",
    "test": "vitest run",
    "routing:mine": "tsx scripts/mine-routing-examples.ts",
    "routing:queue": "tsx scripts/build-routing-label-queue.ts",
    "routing:autolabel": "tsx scripts/auto-label-routing-queue.ts",
    "routing:advisor-log": "tsx scripts/mine-advisor-router-log.ts",
    "sessions:model-outcomes": "tsx scripts/mine-session-model-outcomes.ts",
    "binary:build": "npx tsx scripts/build-binary-gate-dataset.ts",
    "binary:train": "npx tsx scripts/train-binary-gate.ts",
    "binary:eval-sources": "npx tsx scripts/eval-binary-gate-sources.ts",
    "binary:review-conflicts": "npx tsx scripts/review-binary-gate-conflicts.ts",
    "binary:eval-candidates": "npx tsx scripts/eval-binary-gate-candidate-matrix.ts",
    "binary:eval-file": "npx tsx scripts/eval-binary-gate-file.ts",
    "binary:benchmark": "npx tsx scripts/benchmark-binary-gate.ts",
    "routing:score": "tsx scripts/score-routing-active-learning.ts",
    "routing:eval": "tsx scripts/eval-routing-baselines.ts",
    "router:rebuild": "tsx packages/router/src/cli.ts rebuild",
    "router:decide": "tsx packages/router/src/cli.ts decide",
    "router:cards": "tsx packages/router/src/cli.ts cards",
    "router:outcomes": "tsx packages/router/src/cli.ts outcomes",
    "router:outcome-enrich": "tsx packages/router/src/cli.ts outcome-enrich",
    "router:teacher-requests": "tsx packages/router/src/cli.ts teacher-requests",
    "router:teacher-label": "tsx packages/router/src/cli.ts teacher-label",
    "router:reflect": "tsx packages/router/src/cli.ts reflect",
    "router:dataset": "tsx packages/router/src/cli.ts dataset",
    "router:gate-train": "tsx packages/router/src/cli.ts gate-train",
    "router:report": "tsx packages/router/src/cli.ts report",
    "fusion:bench": "tsx scripts/bench-fusion.ts",
    "router:sharpen": "tsx packages/router/src/cli.ts sharpen",
    "router:sharpen:auto": "tsx scripts/router-auto-sharpen.ts",
    "router:shadow": "tsx packages/router/src/cli.ts shadow",
    "board:eval": "tsx scripts/select-board-fixtures.ts",
    "budget-board:smoke": "tsx scripts/smoke-budget-board-profile.ts"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
