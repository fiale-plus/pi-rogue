{
  "name": "@fiale-plus/pi-rogue-bundle",
  "version": "0.1.2",
  "description": "Public Pi-Rogue bundle for advisor, orchestration, and context broker. Single consolidated artefact (leaf releases paused; private packages are bundled here).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fiale-plus/pi-rogue"
  },
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "test": "cd ../.. && vitest run packages/bundle/src/*.test.ts"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./context-broker": "./src/context-broker.ts",
    "./context-broker/file": "./src/context-broker-file.ts",
    "./context-broker/sqlite": "./src/context-broker-sqlite.ts"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "skills": [
      "./node_modules/@fiale-plus/pi-rogue-advisor/skills",
      "./node_modules/@fiale-plus/pi-rogue-orchestration/skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "dependencies": {
    "@fiale-plus/pi-core": "^0.1.0",
    "@fiale-plus/pi-rogue-advisor": "^0.1.0",
    "@fiale-plus/pi-rogue-context-broker": "^0.1.0",
    "@fiale-plus/pi-rogue-orchestration": "^0.1.0"
  },
  "bundledDependencies": [
    "@fiale-plus/pi-core",
    "@fiale-plus/pi-rogue-advisor",
    "@fiale-plus/pi-rogue-context-broker",
    "@fiale-plus/pi-rogue-orchestration"
  ],
  "publishConfig": {
    "access": "public"
  }
}
