{
  "name": "@fiale-plus/pi-rogue-advisor",
  "version": "0.1.5",
  "description": "Pi-Rogue advisor extension for Pi — multi-model support, SOTA model suggestion, cache-aware session advisory. (Releases paused; consolidated into @fiale-plus/pi-rogue-bundle. Install the bundle instead.)",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fiale-plus/pi-rogue.git"
  },
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "check": "tsc -p ../../tsconfig.json --noEmit",
    "test": "cd ../.. && vitest run packages/advisor/src/*.test.ts",
    "board:eval": "cd ../.. && tsx scripts/select-board-fixtures.ts"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "pi": {
    "extensions": [
      "./advisor"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0"
  },
  "dependencies": {
    "@fiale-plus/pi-core": "^0.1.0",
    "typebox": "^1.1.24"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "advisor",
    "src",
    "board",
    "skills",
    "assets",
    "README.md",
    "package.json"
  ]
}
